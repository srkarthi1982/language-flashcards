---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";

const title = "Language Flashcards | Ansiversa";
const description =
  "Create, organize, and review language flashcards in a premium personal workspace.";
---

<AppShell title={title} description={description}>
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker"><span>Language Learning · Ansiversa Mini App</span></div>
        <h1 class="av-gradient-text">Build your language memory, one card at a time.</h1>
        <p>
          Language Flashcards gives you a clean workspace for vocabulary mastery with favorites,
          organized decks, archive history, and focused review.
        </p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Open Workspace</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">Everything you need in V1</h2>
      </div>
      <ul class="av-section-body list-disc space-y-2 pl-5 text-slate-300">
        <li>Create and edit cards with front/back, pronunciation, examples, and notes.</li>
        <li>Organize by language, deck, and topic with lightweight filters.</li>
        <li>Favorite key flashcards, archive older ones, and keep full history.</li>
      </ul>
    </AvContainer>
  </section>
</AppShell>
