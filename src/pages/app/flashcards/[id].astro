---
import AppShell from "../../../layouts/AppShell.astro";
import AvMiniAppBar from "../../../components/AvMiniAppBar.astro";
import { actions } from "astro:actions";
import { getLanguageFlashcardDetailForUser } from "../../../lib/flashcards";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/");
}

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) {
  return Astro.redirect("/app");
}

const flashcard = await getLanguageFlashcardDetailForUser(id, user.id);
if (!flashcard) {
  return new Response("Not found", { status: 404 });
}
---

<AppShell title={flashcard.frontText} description={flashcard.backText}>
  <AvMiniAppBar appKey="language-flashcards" title="Flashcard detail" subtitle="Focused card view" />
  <main class="mx-auto max-w-4xl space-y-5 px-4 py-6 sm:px-6 lg:px-8">
    <a href="/app" class="av-btn av-btn--secondary">← Back to workspace</a>

    <article class="rounded-2xl border border-white/10 bg-slate-900/80 p-6">
      <p class="mb-2 text-sm text-slate-400">
        {flashcard.language ?? "Any language"} · {flashcard.deck ?? "General"} · {flashcard.topic ?? "No topic"}
      </p>
      <h1 class="text-3xl font-semibold text-white">{flashcard.frontText}</h1>
      <p class="mt-3 text-xl text-slate-100">{flashcard.backText}</p>

      {flashcard.pronunciation && (
        <p class="mt-4 rounded-lg bg-slate-950/70 p-3 text-slate-200">
          <strong>Pronunciation:</strong> {flashcard.pronunciation}
        </p>
      )}

      {flashcard.exampleText && (
        <p class="mt-3 rounded-lg bg-slate-950/70 p-3 text-slate-200">
          <strong>Example:</strong> {flashcard.exampleText}
        </p>
      )}

      {flashcard.notes && (
        <p class="mt-3 rounded-lg bg-slate-950/70 p-3 text-slate-200">
          <strong>Notes:</strong> {flashcard.notes}
        </p>
      )}

      <div class="mt-6 flex flex-wrap gap-2">
        <form method="POST" action={actions.toggleLanguageFlashcardFavorite}>
          <input type="hidden" name="id" value={flashcard.id} />
          <button class="av-btn av-btn--secondary">{flashcard.isFavorite ? "★ Favorited" : "☆ Mark favorite"}</button>
        </form>

        {flashcard.status === "active" ? (
          <form method="POST" action={actions.archiveLanguageFlashcard}>
            <input type="hidden" name="id" value={flashcard.id} />
            <button class="av-btn av-btn--secondary">Archive</button>
          </form>
        ) : (
          <form method="POST" action={actions.restoreLanguageFlashcard}>
            <input type="hidden" name="id" value={flashcard.id} />
            <button class="av-btn av-btn--secondary">Restore</button>
          </form>
        )}
      </div>

      <div class="mt-6 text-sm text-slate-400">
        <p>Created: {new Date(flashcard.createdAt).toLocaleString()}</p>
        <p>Updated: {new Date(flashcard.updatedAt).toLocaleString()}</p>
      </div>
    </article>
  </main>
</AppShell>
